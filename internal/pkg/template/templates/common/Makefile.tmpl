# Makefile para el microservicio {{ .ProjectName }}

.PHONY: proto help

# Ayuda
help:
	@echo "Comandos disponibles:"
	@echo "  make proto    - Generar código Go desde archivos .proto"

# Generación de código gRPC
# Requisitos: protoc, protoc-gen-go, protoc-gen-go-grpc
proto:
	@echo "🏗️ Generando código gRPC..."
	mkdir -p internal/adapters/grpc/proto
	protoc --proto_path=api/proto \
		--go_out=internal/adapters/grpc/proto --go_opt=paths=source_relative \
		--go-grpc_out=internal/adapters/grpc/proto --go-grpc_opt=paths=source_relative \
		api/proto/*.proto
	@echo "✅ Código generado exitosamente."

# Instalación de dependencias (Instrucciones)
deps:
	@echo "🔧 Para compilar los protos necesitas:"
	@echo "1. protoc (Protocol Buffers Compiler)"
	@echo "2. go install google.golang.org/protobuf/cmd/protoc-gen-go@latest"
	@echo "3. go install google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest"
