PORT=8080
ENV=development

# Database Configuration
{{- if eq .DBDriver "PostgreSQL" }}
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME={{ .ProjectName }}
DB_HOST=localhost
DB_PORT=5432
{{- end }}

{{- if eq .DBDriver "MySQL" }}
DB_USER=user
DB_PASSWORD=pass
DB_NAME={{ .ProjectName }}
DB_HOST=localhost
DB_PORT=3306
{{- end }}

{{- if eq .DBDriver "MongoDB" }}
DB_USER=admin
DB_PASSWORD=admin
DB_NAME={{ .ProjectName }}
DB_HOST=localhost
DB_PORT=27017
{{- end }}
